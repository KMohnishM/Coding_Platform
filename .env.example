# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LangSmith / LangChain Configuration
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=hg
LANGSMITH_TRACING_V2=true

# Django Configuration
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True

# Database Configuration (Docker defaults)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Frontend Configuration
VITE_API_URL=http://localhost:8000
